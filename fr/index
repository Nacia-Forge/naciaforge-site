  <!-- ── HEADER SCROLL SPY + BURGER ── -->
  <script>
  (function () {
    var tabs      = document.querySelectorAll('.nf-nav-tab');
    var sections  = ['reality','offer','nf-platform','investment','authority','cta-final'];
    var burger    = document.getElementById('nf-burger');
    var mobileNav = document.getElementById('nf-mobile-nav');
    var mobileTabs = document.querySelectorAll('.nf-mobile-tab');

    /* Scroll spy — highlight active tab */
    function onScroll () {
      var scrollY = window.scrollY + 100;
      var active  = '';
      sections.forEach(function (id) {
        var el = document.getElementById(id);
        if (el && el.offsetTop <= scrollY) active = id;
      });
      tabs.forEach(function (tab) {
        var href = tab.getAttribute('href').replace('#','');
        tab.classList.toggle('nf-active', href === active);
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* Burger toggle */
    if (burger && mobileNav) {
      burger.addEventListener('click', function () {
        var open = mobileNav.classList.toggle('nf-open');
        burger.classList.toggle('nf-open', open);
        burger.setAttribute('aria-expanded', open);
        mobileNav.setAttribute('aria-hidden', !open);
      });
      /* Close drawer when a mobile tab is clicked */
      mobileTabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          mobileNav.classList.remove('nf-open');
          burger.classList.remove('nf-open');
          burger.setAttribute('aria-expanded', false);
          mobileNav.setAttribute('aria-hidden', true);
        });
      });
    }
  })();
  </script>

