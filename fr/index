<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Diagnostic de préparation TIPS | Conseil en approvisionnement autochtone</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet" />
  <style>
    /* ── RESET & VARIABLES ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --teal:        #06B188;
      --teal-dark:   #049a77;
      --teal-light:  #e6f9f4;
      --teal-glow:   rgba(6,177,136,0.15);
      --charcoal:    #333030;
      --charcoal-mid:#4a4646;
      --charcoal-soft:#6b6868;
      --off-white:   #f8f7f5;
      --white:       #ffffff;
      --rule:        rgba(51,48,48,0.12);
      --rule-teal:   rgba(6,177,136,0.3);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      color: var(--charcoal);
      background: var(--white);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── TYPOGRAPHY ── */
    h1, h2, h3, h4 { font-family: 'Playfair Display', serif; line-height: 1.2; }

    /* ── UTILITIES ── */
    .container { max-width: 1080px; margin: 0 auto; padding: 0 28px; }
    .section-label {
      font-family: 'Lato', sans-serif;
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--teal);
      display: block;
      margin-bottom: 14px;
    }

    /* ── HEADER ── */
    #nf-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--rule);
      height: 68px;
      display: flex; flex-direction: column; justify-content: center;
    }
    .nf-header-inner {
      max-width: 1200px; margin: 0 auto;
      padding: 0 28px;
      height: 68px;
      display: flex; align-items: center; gap: 0;
    }
    /* Logo */
    .nf-header-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none;
      margin-right: 40px;
      flex-shrink: 0;
    }
    .nf-logo-img {
      width: 44px; height: 44px;
      object-fit: contain;
      display: block;
    }
    .nf-logo-text {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--charcoal);
      letter-spacing: -0.01em;
      white-space: nowrap;
    }
    .nf-logo-text em {
      font-style: italic;
      color: var(--teal);
    }
    /* Scroll nav tabs */
    .nf-header-nav {
      display: flex; align-items: center; gap: 4px;
      flex: 1;
    }
    .nf-nav-tab {
      font-family: 'Lato', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--charcoal-soft);
      text-decoration: none;
      padding: 8px 14px;
      border-radius: 3px;
      transition: color 0.2s, background 0.2s;
      white-space: nowrap;
    }
    .nf-nav-tab:hover,
    .nf-nav-tab.nf-active { color: var(--teal); background: var(--teal-light); }
    /* Header CTA */
    .nf-header-cta {
      font-family: 'Lato', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--teal);
      text-decoration: none;
      border: 1.5px solid var(--teal);
      padding: 8px 18px;
      border-radius: 3px;
      transition: background 0.2s, color 0.2s;
      flex-shrink: 0;
      margin-left: 16px;
      white-space: nowrap;
    }
    .nf-header-cta:hover { background: var(--teal); color: var(--white); }
    /* Burger button */
    .nf-burger {
      display: none;
      flex-direction: column; justify-content: center; gap: 5px;
      width: 40px; height: 40px;
      background: none; border: none; cursor: pointer;
      margin-left: 12px; padding: 6px; flex-shrink: 0;
    }
    .nf-burger span {
      display: block; width: 22px; height: 2px;
      background: var(--charcoal);
      border-radius: 2px;
      transition: transform 0.25s, opacity 0.25s;
    }
    .nf-burger.nf-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nf-burger.nf-open span:nth-child(2) { opacity: 0; }
    .nf-burger.nf-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    /* Mobile drawer */
    .nf-mobile-nav {
      display: none;
      flex-direction: column;
      background: var(--white);
      border-top: 1px solid var(--rule);
      padding: 12px 20px 20px;
    }
    .nf-mobile-nav.nf-open { display: flex; }
    .nf-mobile-tab {
      font-family: 'Lato', sans-serif;
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--charcoal-mid);
      text-decoration: none;
      padding: 14px 0;
      border-bottom: 1px solid var(--rule);
      transition: color 0.2s;
    }
    .nf-mobile-tab:last-child { border-bottom: none; }
    .nf-mobile-tab:hover { color: var(--teal); }
    .nf-mobile-cta { color: var(--teal); margin-top: 8px; }
    /* Active section indicator via scroll spy */
    @media (max-width: 860px) {
      .nf-header-nav { display: none; }
      .nf-header-cta { display: none; }
      .nf-burger     { display: flex; margin-left: auto; }
      #nf-header     { height: auto; min-height: 60px; }
      .nf-header-inner { height: 60px; }
    }
    @media (max-width: 480px) {
      .nf-logo-text { display: none; }
    }

    /* legacy nav rules removed — header uses #nf-header and .nf-header-* classes */

    /* ── HERO ── */
    #hero {
      min-height: 100vh;
      display: flex; flex-direction: column; justify-content: center;
      padding: 108px 28px 80px;
      position: relative;
      overflow: hidden;
      background: var(--charcoal);
    }
    .hero-texture {
      position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 70% 50%, rgba(6,177,136,0.12) 0%, transparent 70%),
        radial-gradient(ellipse 40% 80% at 10% 90%, rgba(6,177,136,0.07) 0%, transparent 60%);
    }
    /* diagonal accent line */
    .hero-line {
      position: absolute; top: 0; right: 18%;
      width: 1px; height: 100%;
      background: linear-gradient(to bottom, transparent, rgba(6,177,136,0.25) 30%, rgba(6,177,136,0.25) 70%, transparent);
      z-index: 0;
    }
    .hero-inner {
      position: relative; z-index: 1;
      max-width: 1080px; margin: 0 auto; width: 100%;
    }
    .hero-eyebrow {
      font-family: 'Lato', sans-serif;
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--teal);
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 28px;
      opacity: 0; animation: fadeUp 0.7s 0.2s forwards;
    }
    .hero-eyebrow::before {
      content: ''; display: block; width: 32px; height: 1.5px; background: var(--teal);
    }
    #hero h1 {
      font-size: clamp(2.1rem, 5vw, 3.6rem);
      color: var(--white);
      max-width: 820px;
      font-weight: 700;
      letter-spacing: -0.02em;
      opacity: 0; animation: fadeUp 0.7s 0.4s forwards;
    }
    #hero h1 em {
      font-style: italic;
      color: var(--teal);
    }
    .hero-sub {
      margin-top: 26px;
      font-size: clamp(1rem, 2vw, 1.18rem);
      color: rgba(255,255,255,0.72);
      max-width: 620px;
      line-height: 1.75;
      font-weight: 300;
      opacity: 0; animation: fadeUp 0.7s 0.6s forwards;
    }
    .hero-actions {
      margin-top: 42px;
      display: flex; flex-wrap: wrap; align-items: center; gap: 20px;
      opacity: 0; animation: fadeUp 0.7s 0.8s forwards;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--teal);
      color: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 0.88rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 16px 34px;
      border-radius: 3px;
      transition: background 0.2s, transform 0.15s;
      border: none; cursor: pointer;
    }
    .btn-primary:hover { background: var(--teal-dark); transform: translateY(-1px); }
    .btn-primary svg { flex-shrink: 0; }
    .hero-note {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.45);
      font-style: italic;
    }
    .hero-stat-row {
      margin-top: 72px;
      display: flex; flex-wrap: wrap; gap: 0;
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 36px;
      opacity: 0; animation: fadeUp 0.7s 1s forwards;
    }
    .hero-stat {
      flex: 1; min-width: 200px;
      padding: 0 32px 0 0;
      border-right: 1px solid rgba(255,255,255,0.1);
      margin-right: 32px;
    }
    .hero-stat:last-child { border-right: none; margin-right: 0; }
    .hero-stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      color: var(--teal);
    }
    .hero-stat-label {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.4;
      margin-top: 4px;
    }

    /* ── REALITY SECTION ── */
    #reality {
      padding: 96px 28px;
      background: var(--off-white);
    }
    #reality .inner {
      max-width: 1080px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: start;
    }
    #reality h2 {
      font-size: clamp(1.9rem, 3.5vw, 2.6rem);
      color: var(--charcoal);
      font-weight: 700;
    }
    #reality h2 span { color: var(--teal); display: block; }
    .reality-lead {
      margin-top: 20px;
      font-size: 1.05rem;
      color: var(--charcoal-mid);
      line-height: 1.8;
    }
    .reality-close {
      margin-top: 28px;
      font-size: 0.95rem;
      color: var(--charcoal-soft);
      font-style: italic;
      padding-left: 18px;
      border-left: 3px solid var(--teal);
      line-height: 1.7;
    }
    .challenge-list {
      list-style: none;
      display: flex; flex-direction: column; gap: 18px;
    }
    .challenge-list li {
      display: flex; gap: 16px; align-items: flex-start;
      background: var(--white);
      border: 1px solid var(--rule);
      border-left: 3px solid var(--teal);
      padding: 18px 20px;
      border-radius: 3px;
      font-size: 0.95rem;
      color: var(--charcoal-mid);
      line-height: 1.55;
      transition: box-shadow 0.2s;
    }
    .challenge-list li:hover { box-shadow: 0 4px 18px rgba(0,0,0,0.07); }
    .challenge-num {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--teal);
      line-height: 1;
      flex-shrink: 0;
      margin-top: 2px;
    }

    /* ── SHIFT SECTION ── */
    #shift {
      padding: 96px 28px;
      background: var(--charcoal);
      position: relative; overflow: hidden;
    }
    .shift-bg {
      position: absolute; inset: 0; z-index: 0;
      background: radial-gradient(ellipse 60% 60% at 85% 50%, rgba(6,177,136,0.08) 0%, transparent 70%);
    }
    #shift .inner {
      position: relative; z-index: 1;
      max-width: 1080px; margin: 0 auto;
      text-align: center;
    }
    #shift h2 {
      font-size: clamp(1.9rem, 3.5vw, 2.7rem);
      color: var(--white);
      max-width: 700px; margin: 12px auto 0;
    }
    .shift-grid {
      margin-top: 56px;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
    }
    .shift-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      padding: 36px 26px;
      text-align: left;
      transition: background 0.2s;
    }
    .shift-card:hover { background: rgba(6,177,136,0.08); }
    .shift-icon {
      width: 44px; height: 44px;
      background: var(--teal-glow);
      border: 1px solid var(--rule-teal);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 18px;
    }
    .shift-icon svg { color: var(--teal); }
    .shift-card h4 {
      font-size: 1rem;
      color: var(--white);
      font-weight: 600;
      margin-bottom: 10px;
    }
    .shift-card p {
      font-size: 0.88rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.6;
    }
    .shift-coda {
      margin-top: 52px;
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.1rem, 2vw, 1.45rem);
      font-style: italic;
      color: rgba(255,255,255,0.7);
      max-width: 560px; margin-left: auto; margin-right: auto;
    }
    .shift-coda strong { color: var(--teal); font-style: normal; }

    /* ── OFFER SECTION ── */
    #offer {
      padding: 96px 28px;
      background: var(--white);
    }
    #offer .inner {
      max-width: 1080px; margin: 0 auto;
    }
    #offer .offer-header {
      display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end;
      margin-bottom: 60px;
      padding-bottom: 48px;
      border-bottom: 1px solid var(--rule);
    }
    #offer h2 {
      font-size: clamp(1.9rem, 3.5vw, 2.6rem);
      color: var(--charcoal);
      font-weight: 700;
    }
    .offer-intro {
      font-size: 1rem;
      color: var(--charcoal-mid);
      line-height: 1.8;
    }
    .pillars {
      display: grid; grid-template-columns: 1fr 1fr; gap: 3px;
    }
    .pillar {
      background: var(--off-white);
      padding: 36px;
      border-top: 3px solid transparent;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .pillar:hover {
      border-color: var(--teal);
      box-shadow: 0 6px 24px rgba(0,0,0,0.06);
    }
    .pillar-num {
      font-family: 'Playfair Display', serif;
      font-size: 2.4rem;
      font-weight: 900;
      color: var(--teal);
      opacity: 0.35;
      line-height: 1;
      margin-bottom: 10px;
    }
    .pillar h3 {
      font-size: 1.08rem;
      color: var(--charcoal);
      font-weight: 700;
      margin-bottom: 14px;
    }
    .pillar ul {
      list-style: none;
      display: flex; flex-direction: column; gap: 8px;
    }
    .pillar ul li {
      font-size: 0.9rem;
      color: var(--charcoal-mid);
      line-height: 1.55;
      padding-left: 16px;
      position: relative;
    }
    .pillar ul li::before {
      content: '→';
      position: absolute; left: 0;
      color: var(--teal);
      font-size: 0.8rem;
    }

    /* ── DELIVERABLES ── */
    #deliverables {
      padding: 80px 28px;
      background: var(--teal);
    }
    #deliverables .inner {
      max-width: 1080px; margin: 0 auto;
      display: grid; grid-template-columns: auto 1fr; gap: 72px; align-items: center;
    }
    #deliverables h2 {
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      color: var(--white);
      font-weight: 700;
      white-space: nowrap;
    }
    .deliverable-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    }
    .deliverable {
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.25);
      padding: 20px 22px;
      border-radius: 3px;
      display: flex; align-items: flex-start; gap: 14px;
    }
    .deliverable-check {
      width: 22px; height: 22px;
      background: rgba(255,255,255,0.2);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 1px;
    }
    .deliverable-check svg { color: var(--white); }
    .deliverable p {
      font-size: 0.92rem;
      color: var(--white);
      line-height: 1.5;
      font-weight: 400;
    }

    /* ── FIT SECTION ── */
    #fit {
      padding: 96px 28px;
      background: var(--off-white);
    }
    #fit .inner {
      max-width: 1080px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
    }
    #fit h2 {
      font-size: clamp(1.7rem, 3vw, 2.3rem);
      color: var(--charcoal);
      font-weight: 700;
      margin-bottom: 28px;
    }
    .fit-list {
      list-style: none;
      display: flex; flex-direction: column; gap: 14px;
    }
    .fit-list li {
      display: flex; gap: 14px; align-items: flex-start;
      font-size: 0.97rem;
      color: var(--charcoal-mid);
      line-height: 1.6;
    }
    .fit-check {
      width: 22px; height: 22px;
      background: var(--teal-light);
      border: 1.5px solid var(--teal);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 2px;
    }
    .fit-check svg { color: var(--teal); }
    .not-fit-box {
      background: var(--white);
      border: 1px solid var(--rule);
      padding: 36px;
    }
    .not-fit-box h3 {
      font-size: 1rem;
      font-family: 'Lato', sans-serif;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--charcoal-soft);
      margin-bottom: 20px;
    }
    .not-fit-list {
      list-style: none;
      display: flex; flex-direction: column; gap: 13px;
    }
    .not-fit-list li {
      display: flex; gap: 12px; align-items: flex-start;
      font-size: 0.92rem;
      color: var(--charcoal-soft);
      line-height: 1.55;
    }
    .not-fit-x {
      width: 20px; height: 20px;
      background: rgba(51,48,48,0.07);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 2px;
    }
    .not-fit-x svg { color: var(--charcoal-soft); }
    .qualifier-note {
      margin-top: 18px;
      font-size: 0.82rem;
      color: var(--charcoal-soft);
      font-style: italic;
      line-height: 1.6;
    }

    /* ── INVESTMENT ── */
    #investment {
      padding: 96px 28px;
      background: var(--charcoal);
    }
    #investment .inner {
      max-width: 1080px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center;
    }
    #investment h2 {
      font-size: clamp(1.9rem, 3.5vw, 2.6rem);
      color: var(--white);
    }
    .investment-body {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.8;
      margin-top: 18px;
    }
    .price-card {
      background: rgba(6,177,136,0.08);
      border: 1px solid var(--rule-teal);
      padding: 44px;
      position: relative;
    }
    .price-range {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 4vw, 3.4rem);
      color: var(--teal);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .price-unit {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.45);
      margin-top: 8px;
      font-style: italic;
    }
    .price-note {
      margin-top: 28px;
      padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,0.1);
      font-size: 0.88rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.7;
    }
    .price-note strong { color: rgba(255,255,255,0.75); }

    /* ── AUTHORITY CLOSE ── */
    #authority {
      padding: 96px 28px;
      background: var(--white);
    }
    #authority .inner {
      max-width: 760px; margin: 0 auto; text-align: center;
    }
    #authority h2 {
      font-size: clamp(1.9rem, 3.5vw, 2.7rem);
      color: var(--charcoal);
      margin-bottom: 24px;
    }
    .authority-body {
      font-size: 1.05rem;
      color: var(--charcoal-mid);
      line-height: 1.85;
      max-width: 640px; margin: 0 auto;
    }
    .authority-facts {
      margin-top: 52px;
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px;
    }
    .fact {
      background: var(--off-white);
      padding: 30px 24px;
      border-top: 3px solid var(--teal);
      text-align: left;
    }
    .fact-num {
      font-family: 'Playfair Display', serif;
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--teal);
      line-height: 1;
    }
    .fact p {
      margin-top: 8px;
      font-size: 0.85rem;
      color: var(--charcoal-soft);
      line-height: 1.55;
    }
    .fact-source {
      margin-top: 6px;
      font-size: 0.73rem;
      color: rgba(51,48,48,0.4);
      font-style: italic;
    }

    /* ── FINAL CTA ── */
    #cta-final {
      padding: 100px 28px;
      background: var(--charcoal);
      position: relative; overflow: hidden;
    }
    .cta-bg {
      position: absolute; inset: 0; z-index: 0;
      background:
