#nf-bot {
  --teal:      #06B188;
  --teal-dark: #049a77;
  --charcoal:  #333030;
  --white:     #ffffff;
  --off-white: #f8f7f5;
  --rule:      rgba(51,48,48,0.10);

  font-family: 'Lato', sans-serif;
}

/* ── FLOATING TRIGGER BUTTON ── */
#nf-bot .nf-bot-trigger {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 9998;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--teal);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(6,177,136,0.40);
  transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
}
#nf-bot .nf-bot-trigger:hover {
  background: var(--teal-dark);
  transform: translateY(-2px);
  box-shadow: 0 6px 28px rgba(6,177,136,0.50);
}
#nf-bot .nf-bot-trigger svg {
  flex-shrink: 0;
  transition: opacity 0.2s;
}
#nf-bot .nf-bot-trigger .nf-icon-chat { display: block; }
#nf-bot .nf-bot-trigger .nf-icon-close { display: none; }
#nf-bot .nf-bot-trigger.nf-open .nf-icon-chat { display: none; }
#nf-bot .nf-bot-trigger.nf-open .nf-icon-close { display: block; }

/* Pulse ring — draws attention on first load */
#nf-bot .nf-bot-trigger::before {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 2px solid rgba(6,177,136,0.40);
  animation: nfBotPulse 2.5s ease-out infinite;
}
@keyframes nfBotPulse {
  0%   { transform: scale(1);   opacity: 0.7; }
  70%  { transform: scale(1.3); opacity: 0; }
  100% { transform: scale(1.3); opacity: 0; }
}

/* ── CHAT WINDOW ── */
#nf-bot .nf-bot-window {
  position: fixed;
  bottom: 96px;
  right: 28px;
  z-index: 9999;
  width: 380px;
  max-height: 560px;
  background: var(--white);
  border: 1px solid var(--rule);
  border-radius: 4px;
  box-shadow: 0 16px 56px rgba(51,48,48,0.18);
  display: flex;
  flex-direction: column;
  overflow: hidden;

  /* Hidden by default */
  opacity: 0;
  transform: translateY(12px) scale(0.97);
  pointer-events: none;
  transition: opacity 0.22s ease, transform 0.22s ease;
}
#nf-bot .nf-bot-window.nf-open {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: all;
}

/* ── HEADER ── */
#nf-bot .nf-bot-header {
  background: var(--charcoal);
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}
#nf-bot .nf-bot-avatar {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: rgba(6,177,136,0.20);
  border: 1.5px solid rgba(6,177,136,0.40);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--teal);
}
#nf-bot .nf-bot-header-text {
  flex: 1;
}
#nf-bot .nf-bot-name {
  font-family: 'Lato', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
}
#nf-bot .nf-bot-status {
  font-size: 0.72rem;
  font-weight: 400;
  color: rgba(255,255,255,0.45);
  display: flex;
  align-items: center;
  gap: 5px;
  margin-top: 2px;
}
#nf-bot .nf-bot-status::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--teal);
  flex-shrink: 0;
}

/* ── MESSAGES ── */
#nf-bot .nf-bot-messages {
  flex: 1;
  overflow-y: auto;
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  scroll-behavior: smooth;
}
#nf-bot .nf-bot-messages::-webkit-scrollbar {
  width: 4px;
}
#nf-bot .nf-bot-messages::-webkit-scrollbar-track {
  background: transparent;
}
#nf-bot .nf-bot-messages::-webkit-scrollbar-thumb {
  background: rgba(51,48,48,0.15);
  border-radius: 2px;
}

/* Message bubbles */
#nf-bot .nf-msg {
  display: flex;
  gap: 8px;
  align-items: flex-end;
  max-width: 100%;
}
#nf-bot .nf-msg.nf-user {
  flex-direction: row-reverse;
}

#nf-bot .nf-msg-bubble {
  max-width: 82%;
  padding: 11px 14px;
  border-radius: 4px;
  font-size: 0.875rem;
  line-height: 1.6;
}
#nf-bot .nf-msg.nf-bot .nf-msg-bubble {
  background: var(--off-white);
  color: rgba(51,48,48,0.85);
  border: 1px solid var(--rule);
  border-bottom-left-radius: 1px;
}
#nf-bot .nf-msg.nf-user .nf-msg-bubble {
  background: var(--teal);
  color: var(--white);
  border-bottom-right-radius: 1px;
}

/* Booking link inside bot messages */
#nf-bot .nf-msg-bubble a {
  color: var(--teal);
  font-weight: 700;
  text-decoration: underline;
  text-underline-offset: 2px;
}
#nf-bot .nf-msg.nf-user .nf-msg-bubble a {
  color: var(--white);
}

/* Typing indicator */
#nf-bot .nf-typing {
  display: flex;
  gap: 4px;
  align-items: center;
  padding: 12px 14px;
  background: var(--off-white);
  border: 1px solid var(--rule);
  border-radius: 4px;
  border-bottom-left-radius: 1px;
  width: fit-content;
}
#nf-bot .nf-typing span {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(51,48,48,0.30);
  animation: nfTyping 1.2s infinite;
}
#nf-bot .nf-typing span:nth-child(2) { animation-delay: 0.2s; }
#nf-bot .nf-typing span:nth-child(3) { animation-delay: 0.4s; }
@keyframes nfTyping {
  0%, 60%, 100% { transform: translateY(0);    opacity: 0.4; }
  30%            { transform: translateY(-4px); opacity: 1;   }
}

/* ── INPUT ROW ── */
#nf-bot .nf-bot-input-row {
  padding: 12px 14px;
  border-top: 1px solid var(--rule);
  display: flex;
  gap: 8px;
  align-items: flex-end;
  flex-shrink: 0;
  background: var(--white);
}

#nf-bot .nf-bot-input {
  flex: 1;
  border: 1px solid var(--rule);
  border-radius: 3px;
  padding: 10px 13px;
  font-family: 'Lato', sans-serif;
  font-size: 0.875rem;
  color: var(--charcoal);
  background: var(--off-white);
  resize: none;
  outline: none;
  line-height: 1.5;
  max-height: 100px;
  transition: border-color 0.2s;
}
#nf-bot .nf-bot-input:focus {
  border-color: rgba(6,177,136,0.50);
}
#nf-bot .nf-bot-input::placeholder {
  color: rgba(51,48,48,0.35);
}

#nf-bot .nf-bot-send {
  width: 38px;
  height: 38px;
  border-radius: 3px;
  background: var(--teal);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
  color: var(--white);
}
#nf-bot .nf-bot-send:hover { background: var(--teal-dark); }
#nf-bot .nf-bot-send:disabled {
  background: rgba(6,177,136,0.35);
  cursor: not-allowed;
}

/* ── RESPONSIVE ── */
@media (max-width: 480px) {
  #nf-bot .nf-bot-window {
    right: 12px;
    left: 12px;
    width: auto;
    bottom: 88px;
  }
  #nf-bot .nf-bot-trigger {
    right: 16px;
    bottom: 16px;
  }
