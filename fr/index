<script>
(function () {
  var cards      = document.querySelectorAll('#nf-platform .nf-product-card');
  var connectBar = document.getElementById('nf-connect-bar');
  var ctaBlock   = document.getElementById('nf-platform-cta');

  if (!cards.length) return;

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (!entry.isIntersecting) return;
      var el  = entry.target;
      var idx = Array.prototype.indexOf.call(cards, el);
      setTimeout(function () {
        el.classList.add('nf-visible');
      }, idx * 180);
      observer.unobserve(el);
    });
  }, { threshold: 0.10 });

  cards.forEach(function (c) { observer.observe(c); });

  /* Connect bar and CTA fade in as units */
  [connectBar, ctaBlock].forEach(function (el) {
    if (!el) return;
    var elObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('nf-visible');
          elObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    elObs.observe(el);
  });
})();
</script>


